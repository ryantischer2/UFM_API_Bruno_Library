meta {
  name: Start Report
  type: http
  seq: 1
}

post {
  url: {{base_url}}/reports/:report_type
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

params:path {
  report_type: Fabric_Health
}

body:json {
  {
    "duplicate_nodes": true,
    "sm_state": true,
    "non_opt_links": true,
    "non_opt_speed_width": true,
    "link_speed": "ALL",
    "link_width": "ALL",
    "ufm_alarms": true
  }
}
