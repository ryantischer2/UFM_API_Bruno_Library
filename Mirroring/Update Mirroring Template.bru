meta {
  name: Update Mirroring Template
  type: http
  seq: 2
}

put {
  url: {{base_url}}/app/mirrorings
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "system_id": "<system_id>",
    "target_port": "<target_port_id>",
    "packet_size": "200",
    "service_level": "5"
  }
}
