meta {
  name: Update Events Policies
  type: http
  seq: 5
}

patch {
  url: {{base_url}}/app/events_policy
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  [
    {
      "name": "64",
      "to_log": true,
      "to_mail": false,
      "to_snmp": false,
      "to_syslog": false,
      "to_ui": true,
      "use_alarm": false
    }
  ]
}
