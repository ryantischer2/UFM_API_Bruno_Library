meta {
  name: Update Site Credentials
  type: http
  seq: 4
}

put {
  url: {{base_url}}/resources/sites/:site_name/credentials
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

params:path {
  site_name: default
}

body:json {
  {
    "type": "SSH_Server",
    "user": "<username>",
    "password": "<password>",
    "port": 22,
    "timeout": 30
  }
}
