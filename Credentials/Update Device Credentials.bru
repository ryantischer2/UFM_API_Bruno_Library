meta {
  name: Update Device Credentials
  type: http
  seq: 3
}

put {
  url: {{base_url}}/resources/systems/:dev_names/credentials
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

params:path {
  dev_names: <name1>,<name2>
}

body:json {
  {
    "type": "SSH_Server",
    "user": "<username>",
    "password": "<password>",
    "port": 22,
    "timeout": 30
  }
}
